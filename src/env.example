# =============================================================================
# local-ai-sandbox — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This file (.env.example) is safe to commit — it contains no real secrets.
# =============================================================================

# ── Jupyter ──────────────────────────────────────────────────────────────────
# Token required to access JupyterLab at http://localhost:8888
# Generate a strong token: python3 -c "import secrets; print(secrets.token_hex(32))"
JUPYTER_TOKEN=changeme-replace-with-a-strong-token

# ── External AI API Keys (optional — for production promotion) ───────────────
# Used by the API service when pointing at cloud providers instead of Ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info

# ── Ollama ───────────────────────────────────────────────────────────────────
# Overridden in docker-compose.yml to http://ollama:11434 (internal Docker DNS)
# Set this only if pointing your API at a different inference endpoint
OLLAMA_BASE_URL=http://ollama:11434

# ── Training ─────────────────────────────────────────────────────────────────
# Weights & Biases experiment tracking (optional)
WANDB_API_KEY=
WANDB_PROJECT=local-ai-sandbox

# MLflow tracking server URI (optional — leave blank to disable)
MLFLOW_TRACKING_URI=
